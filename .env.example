# NutriQuest AI Runtime (for backend/API integration)
# Frontend currently reads runtime config from window.NQ_AI_CONFIG or localStorage key: nq_ai_config

# Provider: openai-compatible | gemini | azure-openai
NQ_AI_PROVIDER=openai-compatible

# OpenAI-compatible endpoint (server route recommended)
NQ_AI_API_BASE=/api/ai/chat
NQ_AI_STREAM_API_BASE=/api/ai/chat/stream

# Models
NQ_AI_MODEL_FAST=gpt-4.1-mini
NQ_AI_MODEL_STRONG=gpt-4.1
NQ_AI_MODEL_FALLBACK=gpt-4.1-mini

# Reliability
NQ_AI_TIMEOUT_MS=14000
NQ_AI_RETRIES=2
NQ_AI_RETRY_BASE_DELAY_MS=450
NQ_AI_ENABLE_STREAMING=true

# Generation tuning
NQ_AI_TEMPERATURE=0.5
NQ_AI_TOP_P=0.95
NQ_AI_FREQUENCY_PENALTY=0.2
NQ_AI_PRESENCE_PENALTY=0.1
NQ_AI_MAX_OUTPUT_TOKENS=700

# Prompt/context limits
NQ_AI_MAX_USER_PROMPT_CHARS=1800
NQ_AI_MAX_HISTORY_TURNS=12
NQ_AI_MAX_HISTORY_CHARS=3600
NQ_AI_MAX_RAG_CHUNKS=3

# Runtime guardrails
NQ_AI_RATE_LIMIT_PER_MINUTE=14
NQ_AI_ABUSE_COOLDOWN_MS=30000
NQ_AI_CIRCUIT_FAILURE_THRESHOLD=3
NQ_AI_CIRCUIT_COOLDOWN_MS=45000

# Security
# Keep secrets server-side. Do not expose real provider keys in browser.
NQ_SERVER_LLM_API_KEY=replace-on-server-only
